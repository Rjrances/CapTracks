APP_NAME=CapTrack
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=captrack_db
DB_USERNAME=root
DB_PASSWORD=

# ---------------------------------------------------------------------------
# MAIL (Option 1 — Gmail SMTP + App Password — no Google Cloud / OAuth needed)
# ---------------------------------------------------------------------------
# CapTrack sends mail through Laravel’s SMTP driver (student temporary passwords,
# etc.). You only need a normal Gmail account plus an “App Password.”
#
# In Google (browser), logged into the Gmail account you want to send FROM:
#
#   1) Open https://myaccount.google.com/security
#   2) Turn on “2-Step Verification” (required before App Passwords appear).
#   3) Search the page for “App passwords” (or: Google Account → Security →
#      How you sign in to Google → App passwords).
#   4) Create an App Password — choose app “Mail”, device e.g. “CapTrack”.
#   5) Google shows a 16-character password (groups of 4). Copy it exactly.
#
# Copy this block into your real `.env` and fill in the values:
#
#   MAIL_USERNAME      = full Gmail address (e.g. captrack@gmail.com)
#   MAIL_PASSWORD      = the 16-character App Password (NOT your Gmail login)
#   MAIL_FROM_ADDRESS  = usually the same as MAIL_USERNAME (must be allowed to send)
#   MAIL_FROM_NAME     = shown as sender name; "${APP_NAME}" uses APP_NAME above
#
# After saving `.env`, run:  php artisan config:clear
# Test:  php artisan mail:test your.email@gmail.com
#
# If SMTP is wrong, check storage/logs/laravel.log — do not share App Passwords.
#
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
# Laravel 12 mail config reads MAIL_SCHEME; omit to auto-pick smtp (587) vs smtps (465).
# MAIL_SCHEME=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

# No inbox? For local dev only you can log mail instead of sending (no Gmail):
# MAIL_MAILER=log
